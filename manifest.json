{
  "manifest_version": 3,
  "name": "reading assistant",
  "version": "1.0.0",
  "description": "ai-powered reading assistant. ask questions about any webpage content and get intelligent responses.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://api.openai.com/*",
    "http://localhost/*"
  ],
  "background": { 
    "service_worker": "background.js", 
    "type": "module" 
  },
  "action": { 
    "default_title": "reading assistant",
    "default_popup": "options.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "data:image/svg+xml;base64,",
    "48": "data:image/svg+xml;base64,",
    "128": "data:image/svg+xml;base64,"
  }
}